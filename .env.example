# Telegram source ingest. Use user API credentials from my.telegram.org, not a bot token.
LISTING_SOURCE_TELEGRAM_API_ID=
LISTING_SOURCE_TELEGRAM_API_HASH=
LISTING_SOURCE_TELEGRAM_PHONE=
LISTING_SOURCE_TELEGRAM_SESSION=data/listing_source.session

# Optional Telegram notification bot.
LISTING_TELEGRAM_BOT_TOKEN=
LISTING_TELEGRAM_CHAT_ID=

# Bybit trading. Keep disabled in shared examples.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_API_BASE_URL=https://api.bybit.com
BYBIT_SPOT_BUY_ENABLED=0
BYBIT_SPOT_BUY_USDT_AMOUNT=0
BYBIT_SPOT_BUY_MODE=quoteCoin
BYBIT_QUERY_FILL_AFTER_BUY=0
BYBIT_RECV_WINDOW=5000
BYBIT_RESOLVE_DUPLICATE_ORDER_LINK_ID=0
BYBIT_TIMESTAMP_BIAS_MS=-50
BYBIT_CLOCK_GATE_ENABLED=1
BYBIT_MAX_CLOCK_SKEW_MS=1000
BYBIT_CLOCK_AHEAD_MARGIN_MS=100
BYBIT_CLOCK_MAX_RTT_MS=1000
BYBIT_CLOCK_GATE_TIMEOUT_SEC=2

# Fast order transports.
BYBIT_ORDER_TRANSPORT_PREFERENCE=cpp_rest,cpp_ws,python_ws,python_rest
BYBIT_FAST_EXECUTOR_ENABLED=1
BYBIT_FAST_EXECUTOR_AUTO_BUILD=1
BYBIT_FAST_EXECUTOR_PATH=bin/bybit_fast_path
BYBIT_FAST_EXECUTOR_BUILD_SCRIPT=cpp/build_fast_path.sh
BYBIT_WS_ORDER_ENABLED=1
BYBIT_WS_TRADE_URL=wss://stream.bybit.com/v5/trade
BYBIT_WS_ORDER_TIMEOUT_SEC=1
BYBIT_WS_PING_INTERVAL_SEC=15
BYBIT_CPP_WS_EXECUTOR_ENABLED=0
BYBIT_CPP_WS_EXECUTOR_AUTO_BUILD=1
BYBIT_CPP_WS_EXECUTOR_PATH=bin/bybit_ws_trade_path
BYBIT_CPP_WS_EXECUTOR_BUILD_SCRIPT=cpp/build_ws_trade_path.sh
BYBIT_CPP_WS_INSECURE_SKIP_VERIFY=0
# Extreme race multi-ticker fallback only. Keep 0 for strict local-cache gating.
BYBIT_FAST_ORDER_ON_CACHE_MISS=0
# Fastest race launcher requires this so it does not start with a cold/empty
# C++ fast executor spot cache.
BYBIT_REQUIRE_FAST_EXECUTOR_WARMUP=0

# Listing hot path.
LISTING_CLASSIFIER_BACKEND=cpp
LISTING_NATIVE_BENCHMARK_PATH=data/native_classifier_benchmark.json
LISTING_CPP_ULTRA_ENGINE_ENABLED=1
LISTING_CPP_ULTRA_ENGINE_PATH=bin/liblisting_ultra_engine.dylib
# Fastest race launcher sets this to 1 so C++ ultra fallback cannot silently
# start with missing spot cache/order-client warmup.
LISTING_CPP_ULTRA_REQUIRE_WARMUP=0
# Extreme race mode can set this to 1 so Bybit order/create is the authority
# when the local spot-symbol cache misses.
LISTING_CPP_ULTRA_ORDER_ON_CACHE_MISS=0
# Benchmark/self-test only. Real trading must leave this off.
LISTING_CPP_ULTRA_ORDER_PREFLIGHT_ONLY=0
# Extreme race mode only: Telethon/Pyrogram can still trigger the Python C++ fast
# buyer, while TDLib also runs native-buy inside the C++ relay with the same
# orderLinkId duplicate guard.
LISTING_RACE_MIN_READY_BACKENDS=2
LISTING_RACE_TDLIB_NATIVE_BUY_ENABLED=0
LISTING_TDLIB_NATIVE_BUY_ENABLED=1
LISTING_TDLIB_NATIVE_KEEPWARM_INTERVAL=15
LISTING_TDLIB_NATIVE_SYMBOL_REFRESH_INTERVAL=15
LISTING_TDLIB_NATIVE_ORDER_CLIENT_KEEPWARM_ENABLED=1
LISTING_TDLIB_NATIVE_IMMEDIATE_KEEPWARM_REFRESH=1
LISTING_TDLIB_NATIVE_BLOCKING_HOT_ORDER_WARMUP=1
LISTING_TDLIB_NATIVE_ASYNC_ORDER_DISPATCH=1
# Extreme live latency mode: keep the first native order workers busy-spinning
# instead of sleeping on atomic_wait, avoiding a scheduler wake-up on dispatch.
LISTING_TDLIB_NATIVE_WORKER_SPIN_WAIT=1
LISTING_TDLIB_NATIVE_WORKER_SPIN_COUNT=2
LISTING_TDLIB_NATIVE_ORDER_START_SPIN_COUNT=64
# Limit background network-warmed parallel order clients. Order workers still support
# up to MAX_LISTING_TICKERS; extra tickers use the already primed base clients.
LISTING_TDLIB_NATIVE_PARALLEL_KEEPWARM_CLIENTS=4
# Keep 0 for strict "do not order unless TICKERUSDT is in the local spot cache".
# Set to 1 only if you want Bybit order/create to be the authority on cache miss.
LISTING_TDLIB_NATIVE_ORDER_ON_CACHE_MISS=0
# Realtime launch scripts check/refresh this cache before watching live channels.
LISTING_TDLIB_NATIVE_REQUIRE_SYMBOL_CACHE=1
LISTING_TDLIB_NATIVE_SYMBOL_CACHE_PATH=data/tdlib_bybit_spot_symbols.txt
LISTING_TDLIB_NATIVE_SYMBOL_CACHE_MAX_AGE_SEC=300
LISTING_TDLIB_NATIVE_SYMBOL_CACHE_MIN_COUNT=100
# Keep native-buy internal trade timing off for the fastest order path.
# Set to 1 only when measuring native trade elapsed fields.
LISTING_TDLIB_NATIVE_TIMING_ENABLED=0
# Ultra scripts cap native Bybit order response wait so the TDLib receive loop
# does not sit behind a slow post-send response. The order is already sent before
# this timeout can fire; raise it if you require slower exchange responses logged.
LISTING_BYBIT_ORDER_RESPONSE_TIMEOUT_MS=250
# Ultra/trade-post TDLib mode defaults this to on so monitoring is not blocked
# by a latency-only clock calibration round trip.
LISTING_TDLIB_SKIP_CLOCK_CALIBRATION=1
# 0 makes the TDLib relay poll without blocking. This is CPU-expensive but avoids
# adding receive-loop sleep to the local Telegram receipt path in ultra mode.
LISTING_TDLIB_RECEIVE_TIMEOUT_SEC=0
# Set to 0 only when native TDLib buy is the primary path and post-buy Python
# notifications/state writes can lag behind the order. Race mode should keep 1
# so other backends see the native-buy result promptly.
LISTING_TDLIB_FLUSH_LISTING_EVENTS=1
# Set to 0 only for pure TDLib native-buy mode when the C++ relay should skip
# post-buy listingMatched JSON emission and immediately return to TDLib receive.
LISTING_TDLIB_EMIT_LISTING_EVENTS=1
# Diagnostic fallback only. Keep 0 for the fastest TDLib native script so it
# uses the relay-only launcher instead of main.py/Poller.
LISTING_TDLIB_NATIVE_USE_MAIN=0
# Optional: skip TDLib startup username resolve after you know fixed chat ids.
# The fastest realtime scripts default this to the current official Upbit/Bithumb ids.
# The client also writes/reads data/tdlib_watch_chats.json after a successful resolve.
# Format: -1001234567890:upbit_news,-1009876543210:BithumbExchange
LISTING_TDLIB_WATCH_CHATS=
BYBIT_PREFER_CACHED_SYMBOL_CHECK=1
